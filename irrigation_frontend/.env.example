# .env.local - Copie ce fichier en .env.local et modifie selon ton setup
# Ne jamais committer le vrai .env.local dans git

# URL de ton API FastAPI
VITE_API_URL=http://localhost:8000

# Doit correspondre a IRRIGATION_API_KEY cote backend.
# Attention: dans une SPA publique, cette cle est visible dans le navigateur.
# Utiliser une vraie authentification utilisateur en production publique.
VITE_API_KEY=change-me-dev-key

# Pour Docker Compose, le navigateur doit appeler l'URL publique de l'API.
# VITE_API_URL=http://localhost:8000
