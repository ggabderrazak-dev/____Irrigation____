# Copy this file to .env.production on your server, then edit the URLs.

# Public URL used by the browser to call FastAPI.
API_URL=http://YOUR_SERVER_IP:8000

# Public URL of the frontend, allowed by FastAPI CORS.
FRONTEND_URL=http://YOUR_SERVER_IP:5173

# Shared API key required by protected backend endpoints.
# Generate a strong random value in production and keep it secret server-side.
IRRIGATION_API_KEY=change-me-production-key

# Frontend build-time key used by the current SPA client.
# Must match IRRIGATION_API_KEY for the existing browser app to call the API.
VITE_API_KEY=change-me-production-key

# Max protected API calls per client IP per minute.
RATE_LIMIT_PER_MINUTE=60

# SHA-256 checksums required before loading pickle/joblib artifacts.
# Recalculate and update these after each trusted model training/release.
MODEL_SHA256=a8ea3279dead981fbaefb2f720381e46cb14b6a1f26ca31dbdf1b48f79ef7e39
SCALER_SHA256=d6873392ab5a3d5f81090f58d27ec0d868708e07131a5b9eb1f284e32999e040
